# Template file committed to the repo.
# Copy to `.env` on a fresh clone:   cp .env.example .env
# Put real secrets only in `.env.local` (gitignored) or in your host/CI environment.
#
# Symfony loads, in this order:
#   .env  -> .env.local  -> .env.$APP_ENV  -> .env.$APP_ENV.local
# so anything here is just a non-secret default.

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=ChangeMeChangeMeChangeMeChangeMeChangeMe
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
# Set the real passphrase in .env.local (or via environment variables in CI/prod).
JWT_PASSPHRASE=
###< lexik/jwt-authentication-bundle ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> symfony/mercure-bundle ###
MERCURE_URL=https://example.com/.well-known/mercure
MERCURE_PUBLIC_URL=https://example.com/.well-known/mercure
MERCURE_JWT_SECRET="!ChangeThisMercureHubJWTSecretKey!"
###< symfony/mercure-bundle ###

###> symfony/messenger ###
# MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/messages
# MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="postgresql://app:!ChangeMe!@127.0.0.1:5432/app?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> app/infra ###
# Redis is used for the tagged task-listing cache pool (prod).
REDIS_URL=redis://127.0.0.1:6379

# Search driver: "pg" (default, uses the Postgres GIN index) or "elastic".
SEARCH_DRIVER=pg
ELASTICSEARCH_URL=http://127.0.0.1:9200
###< app/infra ###
