{
  "info": {
    "name": "Collaborative Task Management API (Symfony)",
    "description": "End-to-end collection for the Collaborative Task Management API.\n\nUsage:\n1. Select the `Task API (local)` environment (or set `baseUrl` at the collection level).\n2. Run `Auth → Register` once, then `Auth → Login` — the token is auto-saved to `{{token}}`.\n3. Run the requests in `Projects → Create project` (saves `{{projectId}}`), then Tasks / Comments.\n\nResponse envelope: `{ success, data, error?, details? }`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "a1c4b4a6-task-api-symfony-2026"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "userId", "value": "", "type": "string" },
    { "key": "secondUserId", "value": "", "type": "string" },
    { "key": "projectId", "value": "", "type": "string" },
    { "key": "taskId", "value": "", "type": "string" },
    { "key": "commentId", "value": "", "type": "string" },
    { "key": "notificationId", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// nothing global for now"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register — primary user (member)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "if (body && body.data && body.data.user) {",
                  "  pm.collectionVariables.set('userId', body.data.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"supersecret1\",\n  \"name\": \"Alice\",\n  \"role\": \"member\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/register", "host": ["{{baseUrl}}"], "path": ["api", "register"] }
          }
        },
        {
          "name": "Register — second user (for assignments)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "if (body && body.data && body.data.user) {",
                  "  pm.collectionVariables.set('secondUserId', body.data.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"bob@example.com\",\n  \"password\": \"supersecret1\",\n  \"name\": \"Bob\",\n  \"role\": \"member\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/register", "host": ["{{baseUrl}}"], "path": ["api", "register"] }
          }
        },
        {
          "name": "Register — reviewer",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"rev@example.com\",\n  \"password\": \"supersecret1\",\n  \"name\": \"Reviewer\",\n  \"role\": \"reviewer\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/register", "host": ["{{baseUrl}}"], "path": ["api", "register"] }
          }
        },
        {
          "name": "Login (primary) — saves {{token}}",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "const token = body.token || (body.data && body.data.token);",
                  "pm.expect(token, 'token present').to.be.a('string').and.not.empty;",
                  "pm.collectionVariables.set('token', token);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"supersecret1\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/login", "host": ["{{baseUrl}}"], "path": ["api", "login"] }
          }
        },
        {
          "name": "Login (second user) — overwrites {{token}}",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "const token = body.token || (body.data && body.data.token);",
                  "pm.collectionVariables.set('token', token);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"bob@example.com\",\n  \"password\": \"supersecret1\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/login", "host": ["{{baseUrl}}"], "path": ["api", "login"] }
          }
        },
        {
          "name": "Me — current user + Mercure subscribe",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/me", "host": ["{{baseUrl}}"], "path": ["api", "me"] }
          }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "List projects",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/projects?page=1&per_page=15",
              "host": ["{{baseUrl}}"],
              "path": ["api", "projects"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "per_page", "value": "15" }
              ]
            }
          }
        },
        {
          "name": "Create project — saves {{projectId}}",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('projectId', body.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Backend Platform\",\n  \"description\": \"API services and workers\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/projects", "host": ["{{baseUrl}}"], "path": ["api", "projects"] }
          }
        },
        {
          "name": "Show project",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/projects/{{projectId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "projects", "{{projectId}}"]
            }
          }
        },
        {
          "name": "Update project",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Backend Platform v2\",\n  \"description\": \"Renamed\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/projects/{{projectId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "projects", "{{projectId}}"]
            }
          }
        },
        {
          "name": "Add member (uses {{secondUserId}})",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": {{secondUserId}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/projects/{{projectId}}/members",
              "host": ["{{baseUrl}}"],
              "path": ["api", "projects", "{{projectId}}", "members"]
            }
          }
        },
        {
          "name": "Remove member",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/projects/{{projectId}}/members/{{secondUserId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "projects", "{{projectId}}", "members", "{{secondUserId}}"]
            }
          }
        },
        {
          "name": "Delete project",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/projects/{{projectId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "projects", "{{projectId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "List tasks in project (filters + pagination)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/projects/{{projectId}}/tasks?status=todo&sort=-created_at&page=1&per_page=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "projects", "{{projectId}}", "tasks"],
              "query": [
                { "key": "status", "value": "todo", "description": "todo | in-progress | done" },
                { "key": "due_from", "value": "", "disabled": true },
                { "key": "due_to", "value": "", "disabled": true },
                { "key": "q", "value": "", "disabled": true, "description": "search in title/description" },
                { "key": "assignee", "value": "", "disabled": true },
                { "key": "sort", "value": "-created_at", "description": "created_at | updated_at | due_date | title | status (prefix - for DESC)" },
                { "key": "page", "value": "1" },
                { "key": "per_page", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Create task — saves {{taskId}}",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('taskId', body.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Deploy staging pipeline\",\n  \"description\": \"kubernetes rollout\",\n  \"status\": \"todo\",\n  \"due_date\": \"2026-05-01\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/projects/{{projectId}}/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["api", "projects", "{{projectId}}", "tasks"]
            }
          }
        },
        {
          "name": "Show task",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "{{taskId}}"]
            }
          }
        },
        {
          "name": "Update task (partial)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in-progress\",\n  \"title\": \"Deploy staging pipeline (in progress)\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "{{taskId}}"]
            }
          }
        },
        {
          "name": "Assign task (uses {{secondUserId}})",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"assignee_id\": {{secondUserId}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/tasks/{{taskId}}/assign",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "{{taskId}}", "assign"]
            }
          }
        },
        {
          "name": "Unassign task (assignee_id = 0)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"assignee_id\": 0\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/tasks/{{taskId}}/assign",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "{{taskId}}", "assign"]
            }
          }
        },
        {
          "name": "Global full-text search",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/tasks/search?q=pipeline&page=1&per_page=15",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "search"],
              "query": [
                { "key": "q", "value": "pipeline" },
                { "key": "page", "value": "1" },
                { "key": "per_page", "value": "15" }
              ]
            }
          }
        },
        {
          "name": "Delete task",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "{{taskId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Comments",
      "item": [
        {
          "name": "List comments for a task",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/tasks/{{taskId}}/comments?page=1&per_page=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "{{taskId}}", "comments"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "per_page", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Create comment — saves {{commentId}}",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('commentId', body.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Looks good to me — shipping today.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/tasks/{{taskId}}/comments",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "{{taskId}}", "comments"]
            }
          }
        },
        {
          "name": "Update comment",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Edited — deploying tomorrow instead.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/comments/{{commentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "comments", "{{commentId}}"]
            }
          }
        },
        {
          "name": "Delete comment",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/comments/{{commentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "comments", "{{commentId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "List unseen — saves first {{notificationId}}",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "const items = (body.data && body.data.items) || [];",
                  "if (items.length > 0) {",
                  "  pm.collectionVariables.set('notificationId', items[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/notifications/unseen",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notifications", "unseen"]
            }
          }
        },
        {
          "name": "Mark one as read",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/notifications/{{notificationId}}/read",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notifications", "{{notificationId}}", "read"]
            }
          }
        },
        {
          "name": "Mark all as read",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/notifications/read-all",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notifications", "read-all"]
            }
          }
        }
      ]
    },
    {
      "name": "Negative / edge cases",
      "item": [
        {
          "name": "Register — invalid payload (expect 422)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"not-an-email\",\n  \"password\": \"x\",\n  \"name\": \"\",\n  \"role\": \"root\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/register", "host": ["{{baseUrl}}"], "path": ["api", "register"] }
          }
        },
        {
          "name": "Me — no token (expect 401)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/me", "host": ["{{baseUrl}}"], "path": ["api", "me"] }
          }
        },
        {
          "name": "Show task — missing (expect 404)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/tasks/999999",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "999999"]
            }
          }
        },
        {
          "name": "Assign to non-member (expect 400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"assignee_id\": 999999\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/tasks/{{taskId}}/assign",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "{{taskId}}", "assign"]
            }
          }
        }
      ]
    }
  ]
}
